# Rename to secrets.yaml and fill in your credentials
#
# Generate new values:
#   API key (base64, 32 bytes): python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#   OTA password (hex):         python3 -c "import secrets; print(secrets.token_hex(16))"
#   AP password:                python3 -c "import secrets; print(secrets.token_urlsafe(9))"

wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"
api_encryption_key: "generate_new_base64_key_here"
ota_password: "generate_new_hex_password_here"
ap_password: "generate_new_password_here"
